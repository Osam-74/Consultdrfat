rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    // Practitioner is identified via a Firestore config doc so we don't need
    // to hard-code a UID in rules (which breaks when UID is not yet known at
    // deploy time).  The /config/practitioner doc must exist with field `uid`.
    function practitionerUid() {
      return get(/databases/$(database)/documents/config/practitioner).data.uid;
    }
    function isPractitioner() {
      return request.auth != null && request.auth.uid == practitionerUid();
    }
    function signedIn() { return request.auth != null; }

    // ── Config (read-only to all, write only to current practitioner) ────────
    // Bootstrap: first write allowed when doc doesn't exist yet.
    match /config/{doc} {
      allow read: if true;
      allow write: if isPractitioner()
        || !exists(/databases/$(database)/documents/config/practitioner);
    }

    // ── Practice data (public read, practitioner write) ──────────────────────
    match /settings/{doc}            { allow read: if true; allow write: if isPractitioner(); }
    match /availabilityTemplates/{d} { allow read: if true; allow write: if isPractitioner(); }
    match /availabilityExceptions/{d}{ allow read: if true; allow write: if isPractitioner(); }

    // ── Bookings ─────────────────────────────────────────────────────────────
    match /bookings/{id} {
      // Single-document read: practitioner or the booking's own client.
      allow get:    if isPractitioner()
        || (signedIn() && resource.data.clientId == request.auth.uid);
      // Collection query: allow when the query is scoped to the caller's own uid.
      // Firestore cannot evaluate resource.data during query planning, so we must
      // allow list for authenticated users and rely on the where("clientId","==",uid)
      // clause in the query to restrict results at the SDK level.
      allow list:   if isPractitioner()
        || signedIn();
      allow create: if signedIn()
        && request.resource.data.clientId == request.auth.uid;
      allow update: if isPractitioner()
        || (signedIn() && resource.data.clientId == request.auth.uid);
    }

    // ── Sessions ─────────────────────────────────────────────────────────────
    match /sessions/{bookingId} {
      function bookingOwner() {
        return get(/databases/$(database)/documents/bookings/$(bookingId)).data.clientId;
      }
      allow read, write: if isPractitioner()
        || (signedIn() && bookingOwner() == request.auth.uid);

      match /messages/{m} {
        allow read, create: if isPractitioner()
          || (signedIn() && get(/databases/$(database)/documents/bookings/$(bookingId)).data.clientId == request.auth.uid);
      }
    }

    // ── WebRTC signaling ─────────────────────────────────────────────────────
    match /calls/{bookingId} {
      allow read, write: if isPractitioner()
        || (signedIn() && get(/databases/$(database)/documents/bookings/$(bookingId)).data.clientId == request.auth.uid);
      match /{sub}/{doc} {
        allow read, write: if isPractitioner()
          || (signedIn() && get(/databases/$(database)/documents/bookings/$(bookingId)).data.clientId == request.auth.uid);
      }
    }

    // ── Mail queue ───────────────────────────────────────────────────────────
    match /mail/{id} { allow create: if signedIn(); allow read, update, delete: if false; }
  }
}
