rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // The practitioner is identified by a single UID set at deploy time.
    function isPractitioner() {
      return request.auth != null
        && request.auth.uid == 'REPLACE_WITH_PRACTITIONER_UID';
    }
    function signedIn() { return request.auth != null; }

    // Public read of practice settings & availability; only the practitioner writes.
    match /settings/{doc}            { allow read: if true; allow write: if isPractitioner(); }
    match /availabilityTemplates/{d} { allow read: if true; allow write: if isPractitioner(); }
    match /availabilityExceptions/{d}{ allow read: if true; allow write: if isPractitioner(); }

    // Bookings: a client creates their own; both owner and practitioner can read;
    // the practitioner manages status.
    match /bookings/{id} {
      allow read:   if isPractitioner() || (signedIn() && resource.data.clientId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.clientId == request.auth.uid;
      allow update: if isPractitioner()
        || (signedIn() && resource.data.clientId == request.auth.uid);
    }

    // A session belongs to a booking; participants (client/practitioner) read & write.
    match /sessions/{bookingId} {
      function bookingOwner() {
        return get(/databases/$(database)/documents/bookings/$(bookingId)).data.clientId;
      }
      allow read, write: if isPractitioner() || (signedIn() && bookingOwner() == request.auth.uid);

      match /messages/{m} {
        allow read, create: if isPractitioner()
          || (signedIn() && get(/databases/$(database)/documents/bookings/$(bookingId)).data.clientId == request.auth.uid);
      }
    }

    // WebRTC signaling docs — same participants as the session.
    match /calls/{bookingId} {
      allow read, write: if isPractitioner()
        || (signedIn() && get(/databases/$(database)/documents/bookings/$(bookingId)).data.clientId == request.auth.uid);
      match /{sub}/{doc} {
        allow read, write: if isPractitioner()
          || (signedIn() && get(/databases/$(database)/documents/bookings/$(bookingId)).data.clientId == request.auth.uid);
      }
    }

    // Outbound email queue (Firebase "Trigger Email" extension). Clients may enqueue
    // only their own notifications; the extension (admin) reads/sends.
    match /mail/{id} { allow create: if signedIn(); allow read, update, delete: if false; }
  }
}
