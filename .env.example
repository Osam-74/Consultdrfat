# ─── Firebase (client SDK — safe to expose; lock data down with Firestore rules) ───
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=consultdrfat.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=consultdrfat
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=consultdrfat.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=101708230797
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Paystack (public key only on the client; SECRET key lives in the Worker) ───
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxx

# ─── Cloudflare Worker base URL (payments verify/webhook + TURN credentials) ───
NEXT_PUBLIC_API_BASE=https://mindbridge-api.<your-subdomain>.workers.dev

# ─── The practitioner's account UID (so the app knows who the admin is) ───
NEXT_PUBLIC_PRACTITIONER_UID=

# NOTE: NEXT_PUBLIC_GOOGLE_CLIENT_ID is no longer needed.
# Google sign-in now uses Firebase's built-in OAuth flow (signInWithPopup/Redirect).
# Simply ensure these are set in Firebase Console:
#   → Authentication → Settings → Authorized domains: add consultdrfat.vercel.app
#   → Authentication → Sign-in method → Google → Enabled
